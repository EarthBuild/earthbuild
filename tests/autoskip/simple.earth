VERSION 0.7
PROJECT testorg/testproj

deps:
  FROM alpine:3.24.0
  COPY my-file .

mytarget:
  FROM +deps
  RUN echo SSB3YXMgcnVuCg== | base64 -d

no-cache:
  FROM alpine:3.24.0
  RUN --no-cache echo "hello"

simple:
  FROM alpine:3.24.0
  RUN echo "hello"

copy-if-exists:
  FROM alpine:3.24.0
  COPY --if-exists my-file .
