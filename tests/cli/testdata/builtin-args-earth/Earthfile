VERSION 0.8
FROM alpine:3.24

builtin-args-test:
    ARG EARTH_TARGET
    ARG EARTH_TARGET_PROJECT
    ARG EARTH_TARGET_NAME
    ARG EARTH_TARGET_TAG
    ARG EARTH_SOURCE_DATE_EPOCH
    ARG EARTH_GIT_COMMIT_TIMESTAMP
    ARG EARTH_GIT_COMMIT_AUTHOR_TIMESTAMP
    ARG EARTH_GIT_BRANCH
    ARG EARTH_GIT_REFS
    ARG EARTH_VERSION
    ARG EARTH_BUILD_SHA
    ARG EARTH_LOCALLY
    ARG EARTH_CI_RUNNER
    RUN echo "$EARTH_TARGET"
    RUN echo "$EARTH_TARGET_PROJECT"
    RUN echo "$EARTH_TARGET_NAME"
    RUN echo "$EARTH_TARGET_TAG"
    RUN echo "$EARTH_VERSION"
    RUN echo "$EARTH_BUILD_SHA"
    RUN test "$EARTH_TARGET" == "+builtin-args-test"
    RUN test -z "$EARTH_TARGET_PROJECT"
    RUN test "$EARTH_TARGET_NAME" == "builtin-args-test"
    RUN test -z "$EARTH_TARGET_TAG"
    RUN test "$EARTH_SOURCE_DATE_EPOCH" = "0"
    RUN test -z "$EARTH_GIT_COMMIT_TIMESTAMP"
    RUN test -z "$EARTH_GIT_COMMIT_AUTHOR_TIMESTAMP"
    RUN test -z "$EARTH_GIT_BRANCH"
    RUN test -z "$EARTH_GIT_REFS"
    RUN test -n "$EARTH_VERSION"
    RUN test -n "$EARTH_BUILD_SHA"
    RUN test "$EARTH_LOCALLY" = "false"
    RUN test -z "$EARTH_CI_RUNNER"
