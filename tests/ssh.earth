VERSION 0.8

test:
    FROM alpine:3.24.1
    RUN apk add --no-cache openssh-client
    RUN test -z "$SSH_AUTH_SOCK"
    RUN --ssh test -n "$SSH_AUTH_SOCK" && ssh-add -l | grep 'rsa-key-from-earthly-tests'

test-with-docker:
    FROM earthbuild/dind:alpine-3.24-docker-29.5.3-r0
    RUN apk add --no-cache openssh-client
    WITH DOCKER
        RUN --ssh test -n "$SSH_AUTH_SOCK" && ssh-add -l | grep 'rsa-key-from-earthly-tests'
    END
